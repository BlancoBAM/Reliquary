# ── Reliquary .gitignore ─────────────────────────────────────────────────────

# ── Build outputs ─────────────────────────────────────────────────────────────
/src-tauri/target/
/dist/
/.next/
/out/
/build/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
# Keep package-lock.json (npm reproducible builds)
# Alternative package-manager lockfiles:
bun.lockb
pnpm-lock.yaml
yarn.lock

# ── OS / system ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
*~

# ── IDE ── keep only .vscode/extensions.json (tool recommendations) ───────────
.idea/
.vscode/settings.json
.vscode/launch.json
.vscode/*.json.bak
*.code-workspace
*.code-profile

# ── AI / agentic tooling (never commit these) ─────────────────────────────────
.claude/
.cursor/
.vibecheck/
.aider*
.continue/
.copilot/
CLAUDE.md
.github/copilot-instructions.md

# ── Dev / analysis notes (version.txt is intentionally kept for update checks) ─
api-design.md
codeanalysis.txt
depslist.txt
frontenddepslist.txt
ref.txt

# ── Legacy filedime / non-standard artifacts ──────────────────────────────────
shell.nix
.ignore
quickintro.png
# Root-level pseudo-workflows dir (real CI lives in .github/workflows/)
/workflows/

# ── Tauri generated files ─────────────────────────────────────────────────────
/src-tauri/gen/